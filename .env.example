# Telegram (получить у @BotFather)
TELEGRAM_TOKEN=

# Админы Telegram user id через запятую
ADMIN_IDS=326666138

# Kie.ai
KIE_API_KEY=
KIE_MODEL=kling-2.6/motion-control
# Обязательное поле API: URL, куда Kie пришлёт callback (можно свой HTTPS или тестовый)
KIE_CALLBACK_URL=https://httpbin.org/post

# Загрузка файлов (Red Panda / Kie file host)
KIE_UPLOAD_BASE=https://kieai.redpandaai.co
# Проверка SSL (1=да). На macOS нужен пакет certifi из requirements.txt. Только для отладки: KIE_SSL_VERIFY=0
KIE_SSL_VERIFY=1

# Тренды: название + URL референс-видео (прямая ссылка на mp4)
TREND_1_NAME=Тренд 1
TREND_1_URL=
TREND_2_NAME=Тренд 2
TREND_2_URL=
TREND_3_NAME=Тренд 3
TREND_3_URL=

# ЮKassa (опционально; без ключей оплата будет недоступна)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Публичный URL бота для return после оплаты (https://t.me/your_bot)
YOOKASSA_RETURN_URL=https://t.me/

# Контент / ссылки
POLICY_URL=https://example.com/policy
SUPPORT_USERNAME=support_username
BOT_USERNAME=your_bot
PROMO_VIDEO_FILE_ID=

# База
DATABASE_URL=sqlite+aiosqlite:///./bot.db
